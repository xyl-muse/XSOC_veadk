# VEADK环境变量配置
SECRET_KEY=your-secret-key-change-in-production

# LLM配置
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# VEADK模型配置
MODEL_AGENT_NAME=your-model-agent-name
MODEL_AGENT_PROVIDER=your-model-provider
MODEL_AGENT_API_BASE=your-model-api-base
MODEL_AGENT_API_KEY=your-model-api-key

# 工具API配置
# 微步威胁情报
THREAT_BOOK_API_KEY=your-threat-book-api-key

# XDR API配置
XDR_API_BASE_URL=https://xdr.example.com/api
XDR_API_KEY=your-xdr-api-key
XDR_HOST=your-xdr-host

# 资产查询API
ASSET_API_BASE_URL=https://asset.example.com/api
ASSET_API_KEY=your-asset-api-key

# NDR API
NDR_API_BASE_URL=https://ndr.example.com/api
NDR_API_KEY=your-ndr-api-key

# EDR API
EDR_API_BASE_URL=https://edr.example.com/api
EDR_API_KEY=your-edr-api-key

# 钉钉API
DINGTALK_APP_KEY=your-dingtalk-app-key
DINGTALK_APP_SECRET=your-dingtalk-app-secret
DINGTALK_AI_TABLE_ID=your-ai-table-id

# 监控配置（可选）
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# 云盘资产数据（JSON字符串格式）
# 从 docs&data_demo/api_docs/CAASM/assets_data.json 读取内容，压缩为单行后设置
# 示例：CLOUD_STORAGE_DATA={"attribution_db":[...],"asset_type_db":[...]}
# 或者直接设置CLOUD_STORAGE_DATA=$(cat docs&data_demo/api_docs/CAASM/assets_data.json | jq -c .)
# 注意：实际部署时应将此值设置为安全的密钥管理服务中
CLOUD_STORAGE_DATA=
