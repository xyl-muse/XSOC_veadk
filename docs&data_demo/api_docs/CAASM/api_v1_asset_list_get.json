{
  "openapi": "3.0.3",
  "info": {
    "title": "Fobrain2.0 CAASM 资产信息查询 API",
    "description": "Fobrain2.0 资产中心 API 接口文档，用于查询互联网和内网资产列表",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{host}",
      "description": "Fobrain 平台服务器",
      "variables": {
        "host": {
          "default": "x.x.x.x",
          "description": "Fobrain 平台地址"
        }
      }
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/api/v1/asset": {
      "get": {
        "tags": [
          "资产中心"
        ],
        "summary": "资产列表",
        "description": "获取资产列表（互联网、内网列表皆使用此接口）",
        "operationId": "getAssetList",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "页码",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "每页数量",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "keyword",
            "in": "query",
            "description": "关键词，模糊搜索",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "field_time",
            "in": "query",
            "description": "时间字段，可选值：created_at, updated_at",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["created_at", "updated_at"]
              }
            }
          },
          {
            "name": "field_sort",
            "in": "query",
            "description": "排序字段",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "field",
            "in": "query",
            "description": "排序字段",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "order",
            "in": "query",
            "description": "排序方式，true 正序，false 倒序",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "recycle",
            "in": "query",
            "description": "回收站筛选，1-不是，2-是，0-所有",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["0", "1", "2"]
              }
            }
          },
          {
            "name": "must_attr",
            "in": "query",
            "description": "必须存在的属性（business-业务系统，department-部门，asset_classification-资产分类）",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["business", "department", "asset_classification"]
              }
            }
          },
          {
            "name": "network_type",
            "in": "query",
            "description": "网络类型，1-内网，2-互联网，0-所有",
            "schema": {
              "type": "integer",
              "enum": [0, 1, 2]
            }
          },
          {
            "name": "search_condition",
            "in": "query",
            "description": "高级筛选条件，JSON字符串格式。示例：{\"all_source_ids\": [1],\"operation_type_string\":\"in\",\"condition\":\"and\"}",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功返回资产列表",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AssetListResponse"
                },
                "example": {
                  "code": 0,
                  "message": "Success",
                  "data": {
                    "total": 85,
                    "page": 1,
                    "per_page": 15,
                    "items": [
                      {
                        "id": "a1b2c3d4e5f678901234567890abcdef",
                        "ip": "x.x.x.x",
                        "ip_type": "IPv4",
                        "hostname": [],
                        "mac": [],
                        "area": "区域A",
                        "business": [],
                        "business_department": ["部门Alpha"],
                        "network_type": "内网",
                        "status": "在线",
                        "os": [],
                        "ports": [
                          {
                            "port": 22,
                            "protocol": "",
                            "status": 0,
                            "url": "",
                            "domain": "",
                            "title": ""
                          }
                        ],
                        "source_names": [
                          {
                            "id": 1,
                            "name": "系统名称A",
                            "en_name": "system_a",
                            "type": "asset_system"
                          }
                        ],
                        "created_at": "2025-01-07 00:00:35",
                        "updated_at": "2025-01-07 00:00:46"
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
