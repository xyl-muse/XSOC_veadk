{
  "openapi": "3.0.3",
  "info": {
    "title": "飞连API - 获取数据防泄漏告警日志",
    "description": "查询终端数据防泄漏(DLP)告警日志，包括文件外发、敏感信息泄露等事件",
    "version": "1.0.0",
    "contact": {
      "name": "飞连 API Support"
    }
  },
  "servers": [
    {
      "url": "https://{endpoint}",
      "description": "飞连平台服务器",
      "variables": {
        "endpoint": {
          "default": "feilian.example.com",
          "description": "飞连平台地址"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "security",
      "description": "终端安全接口"
    }
  ],
  "paths": {
    "/api/open/v1/security/edlp/events/list": {
      "get": {
        "tags": ["security"],
        "summary": "获取数据防泄漏告警日志",
        "description": "查询终端数据防泄漏告警日志，需要接口权限【终端安全-获取终端数据防泄漏告警日志】以及对应用户的权限",
        "operationId": "listEdlpEvents",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "schema": {"type": "string"},
            "description": "用户的id，格式为ou_xxx"
          },
          {
            "name": "did",
            "in": "query",
            "schema": {"type": "string"},
            "description": "设备did"
          },
          {
            "name": "device_os",
            "in": "query",
            "schema": {"type": "string"},
            "description": "设备操作系统，windows或mac"
          },
          {
            "name": "file_type",
            "in": "query",
            "schema": {"type": "integer"},
            "description": "文件类型：1纯文本；2 PDF；3 Word；4 Excel；5 PPT；6图片；7压缩包"
          },
          {
            "name": "status",
            "in": "query",
            "schema": {"type": "integer"},
            "description": "账号状态，1:正常运行 2:暂停运行 3:已离职 4:未激活"
          },
          {
            "name": "start_time",
            "in": "query",
            "schema": {"type": "integer"},
            "description": "事件告警开始时间，Unix时间戳(单位秒)"
          },
          {
            "name": "end_time",
            "in": "query",
            "schema": {"type": "integer"},
            "description": "事件告警结束时间，Unix时间戳(单位秒)"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {"type": "integer", "default": 20},
            "description": "单页数据量，默认值20，最大值200"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {"type": "integer", "default": 0},
            "description": "分页数据偏移量，默认0"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {"type": "integer", "description": "错误码"},
                    "action": {"type": "string", "description": "动作"},
                    "message": {"type": "string", "description": "提示信息"},
                    "data": {
                      "type": "object",
                      "properties": {
                        "count": {"type": "integer", "description": "告警数量"},
                        "items": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "event_id": {"type": "string", "description": "事件uuid"},
                              "event_type": {"type": "string", "description": "事件类型，对应管理后台外发类型"},
                              "action_desc": {"type": "string", "description": "具体用户行为，如【浏览器(firefox.exe)外发文件】"},
                              "key_info": {"type": "string", "description": "敏感信息"},
                              "client_ip": {"type": "string", "description": "客户端IP"},
                              "event_unix_time": {"type": "integer", "description": "事件告警时间，Unix时间戳(单位秒)"},
                              "event_report_time": {"type": "integer", "description": "事件上报时间，Unix时间戳(单位秒)"},
                              "screenshot_count": {"type": "integer", "description": "截图取证数量"},
                              "strategy_key": {"type": "string", "description": "命中策略Key"},
                              "strategy_name": {"type": "string", "description": "策略名称"},
                              "device_ip": {"type": "string", "description": "设备IP"},
                              "did": {"type": "string", "description": "设备did"},
                              "device_name": {"type": "string", "description": "设备名称"},
                              "device_hostname": {"type": "string", "description": "设备主机名"},
                              "device_serial_number": {"type": "string", "description": "设备的SN号"},
                              "device_os": {"type": "string", "description": "设备操作系统"},
                              "user_info": {
                                "type": "object",
                                "description": "用户信息",
                                "properties": {
                                  "id": {"type": "string", "description": "用户的id，格式为ou_xxx"},
                                  "full_name": {"type": "string", "description": "用户名"},
                                  "mobile": {"type": "string", "description": "手机号"},
                                  "email": {"type": "string", "description": "邮箱"},
                                  "status": {"type": "integer", "description": "用户状态"},
                                  "department_id": {"type": "string", "description": "部门id，格式为od_xxx"},
                                  "department_path": {"type": "string", "description": "所属部门路径"}
                                }
                              },
                              "file_info": {
                                "type": "object",
                                "description": "外发文件信息",
                                "properties": {
                                  "name": {"type": "string", "description": "文件名称"},
                                  "path": {"type": "string", "description": "外发路径"},
                                  "type": {"type": "string", "description": "文件类型"},
                                  "size": {"type": "integer", "description": "文件大小(单位byte)"},
                                  "url": {"type": "string", "description": "文件取证url地址"},
                                  "md_5": {"type": "string", "description": "文件md5"}
                                }
                              },
                              "leak_way": {
                                "type": "object",
                                "description": "外发途径",
                                "properties": {
                                  "source_type": {"type": "integer", "description": "外发途径类型，1:桌面软件 2:存储外设 3:浏览器 4:代码 5:剪贴板复制 6:剪贴板粘贴"},
                                  "app_key": {"type": "string", "description": "应用Key"},
                                  "app_name": {"type": "string", "description": "应用名称"},
                                  "app_type": {"type": "string", "description": "应用类型名称"},
                                  "app_desc": {"type": "string", "description": "应用外发描述"},
                                  "is_custom": {"type": "boolean", "description": "是否为自定义应用"}
                                }
                              },
                              "event_result": {
                                "type": "object",
                                "description": "事件处置结果",
                                "properties": {
                                  "screenshot": {"type": "boolean", "description": "截图存证"},
                                  "upload_file": {"type": "boolean", "description": "文件存档"},
                                  "alert": {"type": "boolean", "description": "告警上报"},
                                  "file_flow": {"type": "boolean", "description": "文件流转"},
                                  "intercept": {"type": "boolean", "description": "文件阻断"}
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "访问令牌认证"
      }
    }
  }
}
