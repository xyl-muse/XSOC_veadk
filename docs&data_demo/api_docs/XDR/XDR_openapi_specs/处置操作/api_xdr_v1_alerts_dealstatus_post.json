{
  "openapi": "3.0.3",
  "info": {
    "title": "XDR平台API - 安全告警模块(第二部分)",
    "description": "XDR平台安全告警相关API接口，包括告警处置、查询、安全日志等功能",
    "version": "1.0.0",
    "contact": {
      "name": "XDR API Support"
    }
  },
  "servers": [
    {
      "url": "https://{host}",
      "description": "XDR平台服务器",
      "variables": {
        "host": {
          "default": "xdr.example.com",
          "description": "XDR平台主机地址"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/xdr/v1/alerts/dealstatus": {
      "post": {
        "tags": [
          "alerts"
        ],
        "summary": "批量修改安全告警处置接口",
        "description": "批量修改安全告警的处置状态",
        "operationId": "updateAlertDealStatus",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "uuIds",
                  "dealStatus"
                ],
                "properties": {
                  "uuIds": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "告警ID列表"
                  },
                  "dealStatus": {
                    "type": "integer",
                    "description": "处置状态，1:待处置,2:处置中,3:处置完成",
                    "enum": [
                      1,
                      2,
                      3
                    ]
                  },
                  "dealComment": {
                    "type": "string",
                    "description": "操作备注"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "string",
                      "example": "Success"
                    },
                    "message": {
                      "type": "string",
                      "example": "修改处置状态成功"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "total": {
                          "type": "integer",
                          "description": "更新告警总数"
                        },
                        "succeededNum": {
                          "type": "integer",
                          "description": "更新成功告警数"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT Token认证，在Header中添加Authorization: Bearer {token}"
      }
    }
  }
}