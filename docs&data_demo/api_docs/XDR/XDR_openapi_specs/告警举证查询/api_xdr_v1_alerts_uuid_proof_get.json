                            },
                            "cve": {
                              "type": "string"
                            },
                            "vulType": {
                              "type": "string"
                            },
                            "appType": {
                              "type": "string"
                            },
                            "languageType": {
                              "type": "string"
                            },
                            "proto": {
                              "type": "string"
                            },
                            "ruleName": {
                              "type": "string"
                            },
                            "cmdLine": {
                              "type": "string"
                            },
                            "name": {
                              "type": "string"
                            },
                            "pid": {
                              "type": "string"
                            },
                            "path": {
                              "type": "string"
                            },
                            "regKey": {
                              "type": "string"
                            },
                            "regValue": {
                              "type": "string"
                            },
                            "fileMd5": {
                              "type": "string"
                            },
                            "user": {
                              "type": "string"
                            },
                            "taskFrequency": {
                              "type": "string"
                            }
                          }
                        },
                        "gptResult": {
                          "type": "integer",
                          "description": "GPT研判结论"
                        },
                        "gptResultDescription": {
                          "type": "string",
                          "description": "GPT研判结论中文描述"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
