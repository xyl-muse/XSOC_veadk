                              "type": "string"
                            },
                            "engineName": {
                              "type": "string"
                            },
                            "srcIp": {
                              "type": "string"
                            },
                            "dstIp": {
                              "type": "string"
                            },
                            "mitreIds": {
                              "type": "array",
                              "items": {
                                "type": "string"
                              }
                            },
