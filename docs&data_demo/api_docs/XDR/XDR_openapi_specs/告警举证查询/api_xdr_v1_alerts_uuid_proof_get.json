                        },
                        "proofType": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          },
                          "description": "举证类型"
                        },
                        "proof": {
                          "type": "object",
                          "description": "举证详情，根据proofType取对应字段",
                          "additionalProperties": true
                        },
                        "originalAlert": {
                          "type": "object",
                          "description": "E侧进程链原始告警举证",
                          "properties": {
