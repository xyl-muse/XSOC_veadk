{
  "openapi": "3.0.3",
  "info": {
    "title": "XDR平台API - 安全告警模块(第一部分)",
    "description": "XDR平台安全告警相关API接口，包括告警聚合统计、ATT&CK信息查询、告警举证等功能",
    "version": "1.0.0",
    "contact": {
      "name": "XDR API Support"
    }
  },
  "servers": [
    {
      "url": "https://{host}",
      "description": "XDR平台服务器",
      "variables": {
        "host": {
          "default": "xdr.example.com",
          "description": "XDR平台主机地址"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/xdr/v1/alerts/{uuid}/proof": {
      "get": {
        "tags": [
          "alerts"
        ],
        "summary": "根据告警uuId获取举证信息",
        "description": "获取指定安全告警的详细举证信息",
        "operationId": "getAlertProof",
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "告警ID"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "string",
                      "example": "Success"
                    },
                    "message": {
                      "type": "string",
                      "example": "成功"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string",
                          "description": "告警名称"
                        },
                        "uuId": {
                          "type": "string",
                          "description": "告警ID"
                        },
                        "severity": {
                          "type": "integer",
                          "description": "告警等级"
                        },
                        "threatDefine": {
                          "type": "array",
                          "items": {
                            "type": "integer"
                          },
                          "description": "告警定性"
                        },
                        "direction": {
                          "type": "integer",
                          "description": "访问方向"
                        },
                        "attackResult": {
                          "type": "integer",
                          "description": "攻击结果"
                        },
                        "threatSubTypeDesc": {
                          "type": "string",
                          "description": "告警三级分类"
                        },
                        "stage": {
                          "type": "integer",
                          "description": "告警阶段"
                        },
                        "engineName": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          },
                          "description": "检测引擎"
                        },
                        "logCount": {
                          "type": "integer",
                          "description": "命中日志数"
                        },
                        "lastTime": {
                          "type": "integer",
                          "format": "int64",
                          "description": "最近发生时间"
                        },
                        "srcIp": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          },
                          "description": "源IP"
                        },
                        "srcPort": {
                          "type": "array",
                          "items": {
                            "type": "integer"
                          },
                          "description": "源端口"
                        },
                        "dstIp": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          },
                          "description": "目的IP"
                        },
                        "dstPort": {
                          "type": "array",
                          "items": {
                            "type": "integer"
                          },
                          "description": "目的端口"
                        },
                        "devSourceName": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          },
                          "description": "设备来源"
                        },
                        "dealStatus": {
                          "type": "integer",
