{
  "openapi": "3.0.3",
  "info": {
    "title": "XDR平台API - 安全告警模块(第一部分)",
    "description": "XDR平台安全告警相关API接口，包括告警聚合统计、ATT&CK信息查询、告警举证等功能",
    "version": "1.0.0",
    "contact": {
      "name": "XDR API Support"
    }
  },
  "servers": [
    {
      "url": "https://{host}",
      "description": "XDR平台服务器",
      "variables": {
        "host": {
          "default": "xdr.example.com",
          "description": "XDR平台主机地址"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/xdr/v1/alerts/ipInfos": {
      "post": {
        "tags": [
          "alerts-stats"
        ],
        "summary": "IP信息聚合",
        "description": "查询IP信息聚合统计",
        "operationId": "getAlertIpInfos",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "startTimestamp",
                  "endTimestamp",
                  "timeField",
                  "aggBy",
                  "limit"
                ],
                "properties": {
                  "startTimestamp": {
                    "type": "integer",
                    "format": "int64",
                    "description": "开始时间戳"
                  },
                  "endTimestamp": {
                    "type": "integer",
                    "format": "int64",
                    "description": "结束时间戳"
                  },
                  "timeField": {
                    "type": "string",
                    "description": "过滤的时间字段"
                  },
                  "filterParam": {
                    "type": "object",
                    "properties": {
                      "accessDirections": {
                        "type": "array",
                        "items": {
                          "type": "integer"
                        },
                        "description": "告警访问方向"
                      },
                      "hostBranchIds": {
                        "type": "array",
                        "items": {
                          "type": "integer"
                        },
                        "description": "资产组"
                      },
                      "severities": {
                        "type": "array",
                        "items": {
                          "type": "integer"
                        },
                        "description": "告警等级"
                      },
                      "whiteStatus": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "description": "加白状态"
                      },
                      "devUids": {
                        "type": "array",
                        "items": {
                          "type": "integer"
                        },
                        "description": "数据源ID"
                      },
                      "alarmClassifications": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "description": "告警分类"
                      },
                      "hostGroupIds": {
                        "type": "array",
                        "items": {
                          "type": "integer"
                        },
                        "description": "业务组过滤"
                      },
                      "platformIds": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "description": "平台ID"
                      }
                    }
                  },
                  "aggBy": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "分组字段，参数可以srcIpInfos开头，也可以dstIpInfos开头"
                  },
                  "limit": {
                    "type": "integer",
                    "description": "返回数量"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "string",
                      "example": "Success"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "item": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "ip": {
                                "type": "string",
                                "description": "IP"
                              },
                              "assetId": {
                                "type": "integer",
                                "description": "资产组ID"
                              },
                              "branchId": {
                                "type": "integer",
                                "description": "分支ID"
                              },
                              "classifyId": {
                                "type": "integer",
                                "description": "资产具体类型"
                              },
                              "classify1Id": {
                                "type": "integer",
                                "description": "资产父类型"
                              },
                              "provinceName": {
                                "type": "string",
                                "description": "省份名称"
                              },
                              "countryName": {
                                "type": "string",
                                "description": "国家名称"
                              },
                              "value": {
                                "type": "integer",
                                "description": "安全告警条数"
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
