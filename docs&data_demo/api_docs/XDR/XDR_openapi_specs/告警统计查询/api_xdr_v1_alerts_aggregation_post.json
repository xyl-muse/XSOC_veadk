{
  "openapi": "3.0.3",
  "info": {
    "title": "XDR平台API - 安全告警模块(第一部分)",
    "description": "XDR平台安全告警相关API接口，包括告警聚合统计、ATT&CK信息查询、告警举证等功能",
    "version": "1.0.0",
    "contact": {
      "name": "XDR API Support"
    }
  },
  "servers": [
    {
      "url": "https://{host}",
      "description": "XDR平台服务器",
      "variables": {
        "host": {
          "default": "xdr.example.com",
          "description": "XDR平台主机地址"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/xdr/v1/alerts/aggregation": {
      "post": {
        "tags": [
          "alerts-stats"
        ],
        "summary": "告警聚合通用API",
        "description": "告警聚合统计通用接口",
        "operationId": "aggregateAlerts",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "startTimestamp",
                  "endTimestamp",
                  "timeField",
                  "aggFuncs"
                ],
                "properties": {
                  "startTimestamp": {
                    "type": "integer",
                    "format": "int64",
                    "description": "起始时间戳"
                  },
                  "endTimestamp": {
                    "type": "integer",
                    "format": "int64",
                    "description": "结束时间戳"
                  },
                  "timeField": {
                    "type": "string",
                    "description": "过滤的时间字段"
                  },
                  "filterParam": {
                    "type": "object",
                    "properties": {
                      "alertDealStatus": {
                        "type": "array",
                        "items": {
                          "type": "integer"
                        },
                        "description": "处置状态，1:待处置,2:处置中,3:处置完成"
                      },
                      "alertDealActions": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "description": "处置动作"
                      },
                      "accessDirections": {
                        "type": "array",
                        "items": {
                          "type": "integer"
                        },
                        "description": "访问方向"
                      },
                      "hostBranchIds": {
                        "type": "array",
                        "items": {
                          "type": "integer"
                        },
                        "description": "资产组"
                      },
                      "threatDefines": {
                        "type": "array",
                        "items": {
                          "type": "integer"
                        },
                        "description": "告警定性"
                      },
                      "hostBusinessIds": {
                        "type": "array",
                        "items": {
                          "type": "integer"
                        },
                        "description": "所属业务"
                      },
                      "alarmClassifications": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "description": "告警分类"
                      },
                      "severities": {
                        "type": "array",
                        "items": {
                          "type": "integer"
                        },
                        "description": "告警等级"
                      },
                      "read": {
                        "type": "boolean",
                        "description": "告警是否已读"
                      },
                      "whiteStatus": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "description": "告警加白字段"
                      },
                      "manages": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "description": "上报设备ID"
                      },
                      "devUIds": {
                        "type": "array",
                        "items": {
                          "type": "integer"
                        },
                        "description": "数据源-原始"
                      },
                      "attackResults": {
                        "type": "array",
                        "items": {
                          "type": "integer"
                        },
                        "description": "攻击结果"
                      },
                      "srcCountryNames": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "description": "攻击源"
                      },
                      "srcProvinceName": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "description": "省份"
                      },
                      "dstIpsClassify1idList": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "description": "目的IP资产类型"
                      }
                    }
                  },
                  "excludeParam": {
                    "type": "object",
                    "properties": {
                      "manages": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "description": "排除上报设备ID"
                      },
                      "srcCountryNames": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "description": "排除攻击源"
                      },
                      "proofType": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "description": "排除协议类型"
                      },
                      "columns": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "description": "不存在某些字段的数据"
                      },
                      "alertDealActions": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "description": "排除处置动作"
                      }
                    }
                  },
                  "aggBy": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "分组字段"
                  },
                  "aggByAlias": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "分组别名"
                  },
                  "aggFuncs": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string",
                          "description": "聚合结果名称"
                        },
                        "func": {
                          "type": "string",
                          "description": "聚合操作名称"
                        },
                        "param": {
                          "type": "string",
                          "description": "聚合字段"
                        }
                      }
                    }
                  },
                  "sort": {
                    "type": "string",
                    "description": "排序方法"
                  },
                  "limit": {
                    "type": "integer",
                    "description": "TOP数量"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "string",
                      "example": "Success"
                    },
                    "message": {
                      "type": "string",
                      "example": "成功"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "meta": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "name": {
                                "type": "string"
                              },
                              "type": {
                                "type": "string"
                              }
                            }
                          }
                        },
                        "item": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "name": {
                                "type": "string",
                                "description": "分组字段"
                              },
                              "count": {
                                "type": "integer",
                                "description": "统计值"
                              },
                              "branchName": {
                                "type": "string",
                                "description": "资产名称"
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT Token认证，在Header中添加Authorization: Bearer {token}"
