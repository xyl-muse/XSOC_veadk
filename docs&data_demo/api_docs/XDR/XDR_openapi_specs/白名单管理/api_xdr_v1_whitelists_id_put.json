{
  "openapi": "3.0.3",
  "info": {
    "title": "XDR平台API - 白名单模块",
    "description": "XDR平台白名单相关API接口，包括白名单的增删改查功能",
    "version": "1.0.0",
    "contact": {
      "name": "XDR API Support"
    }
  },
  "servers": [
    {
      "url": "https://{host}",
      "description": "XDR平台服务器",
      "variables": {
        "host": {
          "default": "xdr.example.com",
          "description": "XDR平台主机地址"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/xdr/v1/whitelists/{id}": {
      "put": {
        "tags": [
          "whitelists"
        ],
        "summary": "根据ID修改白名单",
        "description": "修改指定ID的白名单配置",
        "operationId": "updateWhitelist",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "白名单ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "status",
                  "isHostAll",
                  "name",
                  "isUnlimited",
                  "ruleList",
                  "threatSubTypeIds"
                ],
                "properties": {
                  "status": {
                    "type": "string",
                    "description": "白名单状态",
                    "enum": [
                      "enable",
                      "disable"
                    ]
                  },
                  "isHostAll": {
                    "type": "boolean",
                    "description": "是否选择全部生效主机"
                  },
                  "hostIp": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "生效主机列表"
                  },
                  "name": {
                    "type": "string",
                    "description": "白名单的规则名称"
                  },
                  "reason": {
                    "type": "string",
                    "description": "备注"
                  },
                  "isUnlimited": {
                    "type": "boolean",
                    "description": "是否永久生效"
                  },
                  "timeRange": {
                    "type": "array",
                    "items": {
                      "type": "integer"
                    },
                    "description": "生效时间，生效起始时间戳和结束时间戳",
                    "minItems": 2,
                    "maxItems": 2
                  },
                  "ruleList": {
                    "type": "array",
                    "description": "白名单匹配规则列表",
                    "items": {
                      "type": "object",
                      "required": [
                        "type",
                        "mode",
                        "view",
                        "isIgnorecase"
                      ],
                      "properties": {
                        "type": {
                          "type": "string",
                          "description": "匹配字段",
                          "enum": [
                            "alertEngine",
                            "alertRuleId",
                            "attackState",
                            "attckSubTechnique",
                            "bfAccountList",
                            "confidence",
                            "domain",
                            "domainAndUrl",
                            "dstIp",
                            "dstPort",
                            "exploitCveId",
                            "fileMd5",
                            "fileName",
                            "filePath",
                            "otherCmdLine",
                            "otherPath",
                            "parentCmdLine",
                            "parentPath",
                            "payload",
                            "productType",
                            "recipient",
                            "requestBody",
                            "requestHead",
                            "respStatus",
                            "responseBody",
                            "responseHead",
                            "riskTag",
                            "ruleIds",
                            "srcIp",
                            "srcPort",
                            "url",
                            "xForwardedFor",
                            "pName",
                            "hostIp"
                          ]
                        },
                        "mode": {
                          "type": "string",
                          "description": "匹配方式",
                          "enum": [
                            "in",
                            "=",
                            "like"
                          ]
                        },
                        "view": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          },
                          "description": "匹配值"
                        },
                        "isIgnorecase": {
                          "type": "boolean",
                          "description": "是否忽略大小写"
                        }
                      }
                    }
                  },
                  "threatSubTypeIds": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "攻击子类，控制使用哪种白名单模板",
                    "example": [
                      "204",
                      "203",
                      "-1"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "string",
                      "example": "Success"
                    },
                    "message": {
                      "type": "string",
                      "example": "成功"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "参数错误",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "string",
                      "example": "InvalidParameter"
                    },
                    "message": {
                      "type": "string",
                      "example": "param mode is illegal;"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT Token认证，在Header中添加Authorization: Bearer {token}"
      }
    },
    "schemas": {
      "WhitelistRule": {
        "type": "object",
        "required": [
          "type",
          "mode",
          "view",
          "isIgnorecase"
        ],
        "properties": {
          "type": {
            "type": "string",
            "description": "匹配字段",
            "enum": [
              "alertEngine",
              "alertRuleId",
              "attackState",
              "attckSubTechnique",
              "bfAccountList",
              "confidence",
              "domain",
              "domainAndUrl",
              "dstIp",
              "dstPort",
              "exploitCveId",
              "fileMd5",
              "fileName",
              "filePath",
              "otherCmdLine",
              "otherPath",
              "parentCmdLine",
              "parentPath",
              "payload",
              "productType",
              "recipient",
              "requestBody",
              "requestHead",
              "respStatus",
              "responseBody",
              "responseHead",
              "riskTag",
              "ruleIds",
              "srcIp",
              "srcPort",
              "url",
              "xForwardedFor",
              "pName",
              "hostIp"
            ]
          },
          "mode": {
            "type": "string",
            "description": "匹配方式",
            "enum": [
              "in",
              "=",
              "like"
            ]
          },
          "view": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "匹配值"
          },
          "isIgnorecase": {
            "type": "boolean",
            "description": "是否忽略大小写"
          }
        }
      },
      "ThreatSubType": {
        "type": "object",
        "properties": {
          "threatSubTypeId": {
            "type": "string",
            "description": "攻击子类ID",
            "enum": [
              "94",
              "214",
              "201",
              "215",
              "90",
              "203",
              "204",
              "205",
              "96",
              "10",
              "207",
              "30",
              "208",
              "213",
              "40",
              "209",
              "212",
              "218",
              "216",
              "217",
              "-1",
              "all"
            ]
          },
          "threatSubTypeView": {
            "type": "string",
            "description": "攻击子类名称"
          }
        }
      }
    }
  }
}