{
  "openapi": "3.0.3",
  "info": {
    "title": "XDR平台API - 白名单模块",
    "description": "XDR平台白名单相关API接口，包括白名单的增删改查功能",
    "version": "1.0.0",
    "contact": {
      "name": "XDR API Support"
    }
  },
  "servers": [
    {
      "url": "https://{host}",
      "description": "XDR平台服务器",
      "variables": {
        "host": {
          "default": "xdr.example.com",
          "description": "XDR平台主机地址"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/xdr/v1/whitelists": {
      "delete": {
        "tags": [
          "whitelists"
        ],
        "summary": "删除白名单",
        "description": "批量删除白名单",
        "operationId": "deleteWhitelists",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "whiteIdList"
                ],
                "properties": {
                  "whiteIdList": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "白名单ID列表"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "string",
                      "example": "Success"
                    },
                    "message": {
                      "type": "string",
                      "example": "成功"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "total": {
                          "type": "integer",
                          "description": "删除白名单总数"
                        },
                        "succeededNum": {
                          "type": "integer",
                          "description": "删除成功的数量"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT Token认证，在Header中添加Authorization: Bearer {token}"
      }
    },
    "schemas": {
      "WhitelistRule": {
        "type": "object",
        "required": [
          "type",
          "mode",
          "view",
          "isIgnorecase"
        ],
        "properties": {
          "type": {
            "type": "string",
            "description": "匹配字段",
            "enum": [
              "alertEngine",
              "alertRuleId",
              "attackState",
              "attckSubTechnique",
              "bfAccountList",
              "confidence",
              "domain",
              "domainAndUrl",
              "dstIp",
              "dstPort",
              "exploitCveId",
              "fileMd5",
              "fileName",
              "filePath",
              "otherCmdLine",
              "otherPath",
              "parentCmdLine",
              "parentPath",
              "payload",
              "productType",
              "recipient",
              "requestBody",
              "requestHead",
              "respStatus",
              "responseBody",
              "responseHead",
              "riskTag",
              "ruleIds",
              "srcIp",
              "srcPort",
              "url",
              "xForwardedFor",
              "pName",
              "hostIp"
            ]
          },
          "mode": {
            "type": "string",
            "description": "匹配方式",
            "enum": [
              "in",
              "=",
              "like"
            ]
          },
          "view": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "匹配值"
          },
          "isIgnorecase": {
            "type": "boolean",
            "description": "是否忽略大小写"
          }
        }
      },
      "ThreatSubType": {
        "type": "object",
        "properties": {
          "threatSubTypeId": {
            "type": "string",
            "description": "攻击子类ID",
            "enum": [
              "94",
              "214",
              "201",
              "215",
              "90",
              "203",
              "204",
              "205",
              "96",
              "10",
              "207",
              "30",
              "208",
              "213",
              "40",
              "209",
              "212",
              "218",
              "216",
              "217",
              "-1",
              "all"
            ]
          },
          "threatSubTypeView": {
            "type": "string",
            "description": "攻击子类名称"
          }
        }
      }
    }
  }
}